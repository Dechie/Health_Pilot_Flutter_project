            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{access_token}}","type": "string"}]},
            "body": {"mode": "raw","raw": "{\n  \"old_password\": \"StrongPass123!\",\n  \"new_password\": \"NewPass456!\",\n  \"new_password2\": \"NewPass456!\"\n}","options": {"raw": {"language": "json"}}}
          }
        },
        {
          "name": "Request Password Reset",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/v1/auth/password/reset/","host": ["{{base_url}}"],"path": ["api","v1","auth","password","reset"]},
            "body": {"mode": "raw","raw": "{\n  \"email\": \"user@example.com\"\n}","options": {"raw": {"language": "json"}}}
          }
        },
        {
          "name": "Confirm Password Reset",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/v1/auth/password/reset/confirm/","host": ["{{base_url}}"],"path": ["api","v1","auth","password","reset","confirm"]},
            "body": {"mode": "raw","raw": "{\n  \"token\": \"paste-token-from-email\",\n  \"new_password\": \"NewPass456!\",\n  \"new_password2\": \"NewPass456!\"\n}","options": {"raw": {"language": "json"}}}
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/v1/auth/me/delete/","host": ["{{base_url}}"],"path": ["api","v1","auth","me","delete"]},
            "auth": {"type": "bearer","bearer": [{"key": "token","value": "{{access_token}}","type": "string"}]},
            "body": {"mode": "raw","raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}","options": {"raw": {"language": "json"}}}
          }
        }
      ]
