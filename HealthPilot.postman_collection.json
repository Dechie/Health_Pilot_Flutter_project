{
  "info": {
    "name": "HealthPilot API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:9000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/v1/auth/register/","host": ["{{base_url}}"],"path": ["api","v1","auth","register"]},
            "body": {"mode": "raw","raw": "{\n  \"email\": \"user@example.com\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"password\": \"StrongPass123!\",\n  \"password2\": \"StrongPass123!\"\n}","options": {"raw": {"language": "json"}}}
          }
        },
        {
          "name": "Activate Account",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/v1/auth/activate/","host": ["{{base_url}}"],"path": ["api","v1","auth","activate"]},
            "body": {"mode": "raw","raw": "{\n  \"token\": \"paste-token-from-email\"\n}","options": {"raw": {"language": "json"}}}
          },
          "event": [{"listen": "test","script": {"exec": ["var res = pm.response.json();","if (res.data && res.data.access) {","  pm.collectionVariables.set('access_token', res.data.access);","  pm.collectionVariables.set('refresh_token', res.data.refresh);","  console.log('Tokens saved');","}"],"type": "text/javascript"}}]
        },
        {
          "name": "Resend Activation",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/v1/auth/resend-activation/","host": ["{{base_url}}"],"path": ["api","v1","auth","resend-activation"]},
            "body": {"mode": "raw","raw": "{\n  \"email\": \"user@example.com\"\n}","options": {"raw": {"language": "json"}}}
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/v1/auth/login/","host": ["{{base_url}}"],"path": ["api","v1","auth","login"]},
            "body": {"mode": "raw","raw": "{\n  \"email\": \"admin@healthpilot.app\",\n  \"password\": \"Admin1234!\"\n}","options": {"raw": {"language": "json"}}}
          },
          "event": [{"listen": "test","script": {"exec": ["var res = pm.response.json();","if (res.data && res.data.access) {","  pm.collectionVariables.set('access_token', res.data.access);","  pm.collectionVariables.set('refresh_token', res.data.refresh);","  console.log('Tokens saved');","}"],"type": "text/javascript"}}]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "url": {"raw": "{{base_url}}/api/v1/auth/token/refresh/","host": ["{{base_url}}"],"path": ["api","v1","auth","token","refresh"]},
            "body": {"mode": "raw","raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}","options": {"raw": {"language": "json"}}}
          }
        },
        {
          "name": "Logout",
